{
  "cli": {
    "version": ">= 13.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "development",
        "EXPO_PUBLIC_API_BASE_URL": "http://10.0.2.2:3000",
        "EXPO_PUBLIC_SOLANA_NETWORK": "devnet",
        "EXPO_PUBLIC_RPC_ENDPOINT": "https://api.devnet.solana.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "https://staging-api.w3bs.fun",
        "EXPO_PUBLIC_SOLANA_NETWORK": "devnet",
        "EXPO_PUBLIC_RPC_ENDPOINT": "https://api.devnet.solana.com"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://api.w3bs.fun",
        "EXPO_PUBLIC_SOLANA_NETWORK": "mainnet-beta",
        "EXPO_PUBLIC_RPC_ENDPOINT": "https://api.mainnet-beta.solana.com"
      }
    }
  }
}
