{
  "name": "goldback-mobile-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "android": "expo run:android",
    "android:dev-client": "expo run:android",
    "android:release:local": "cd android && ./gradlew assembleRelease -Pgoldback.requireReleaseSigning=true",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:build:dev": "npx --yes eas-cli build --platform android --profile development",
    "eas:build:preview": "npx --yes eas-cli build --platform android --profile preview",
    "eas:build:prod": "npx --yes eas-cli build --platform android --profile production",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.6",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.29",
    "@solana-mobile/mobile-wallet-adapter-protocol": "^2.2.5",
    "@solana-mobile/mobile-wallet-adapter-protocol-web3js": "^2.2.5",
    "@solana/web3.js": "^1.98.4",
    "babel-preset-expo": "~54.0.10",
    "buffer": "^6.0.3",
    "expo": "~54.0.0",
    "expo-dev-client": "~6.0.20",
    "expo-status-bar": "~3.0.0",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-get-random-values": "^1.11.0",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}
